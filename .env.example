# =============================================================================
# Agents — Environment Variables
# Copy to .env and fill in: cp .env.example .env
# =============================================================================

# ── Required ─────────────────────────────────────────────────────
# Auth secret — generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# Public URL where Agents will be accessible (e.g. https://agents.cx-assist.io)
# Note: the upstream binary internally reads this as PAPERCLIP_PUBLIC_URL — do not rename.
PAPERCLIP_PUBLIC_URL=https://agents.cx-assist.io

# ── Database ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=

# ── cx-assist Cross-Domain SSO Handoff ───────────────────────────
# Shared secret used to sign / verify SSO tokens between
# app.cx-assist.com and agents.cx-assist.io. MUST match the value
# set on the cx-assist platform side.
#
# Either set JWT_SECRET (matches cx-assist's existing var) OR
# set AGENTS_SSO_SECRET on both sides for isolation. AGENTS_SSO_SECRET
# takes precedence if both are set.
#
# Generate with: openssl rand -hex 64
# See docs/SSO_HANDOFF.md for full setup
JWT_SECRET=
AGENTS_SSO_SECRET=

# ── Cognito SSO (optional) ───────────────────────────────────────
# If all five values below are set, Agents enables "Sign in with cx-assist"
# (AWS Cognito OIDC). Leave empty to fall back to email/password sign-in.
# See docs/COGNITO_SSO.md for AWS Console setup steps.
COGNITO_REGION=eu-west-2
COGNITO_USER_POOL_ID=eu-west-2_pgov6mOhU
COGNITO_DOMAIN=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=

# Admin role enforcement:
#   allow_all     — accept anyone Cognito authenticates (initial rollout)
#   api_check     — POST {sub, email} to COGNITO_ADMIN_VERIFY_URL and require allow=true
#   deny_default  — refuse all logins (use only during maintenance)
COGNITO_ADMIN_CHECK_MODE=allow_all
COGNITO_ADMIN_VERIFY_URL=
COGNITO_ADMIN_VERIFY_TOKEN=

# ── AI Agent API Keys (optional) ─────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
